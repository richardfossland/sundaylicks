# Copy to .env.local and fill in. Uses the SHARED SundaySuite Supabase project
# (same project as SundayChess/Market/Turnering/Quiz) — SundayLicks lives in
# its own `licks` Postgres schema. After running supabase/migrations the
# `licks` schema MUST be added under Settings → API → Exposed schemas.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY
NEXT_PUBLIC_APP_URL=https://licks.sundaysuite.app

# Only needed locally to run `npm run seed` (upserts the curated licks).
# Never deployed to the Worker.
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY
