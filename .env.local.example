# Copy to .env.local and fill in. Uses the SHARED SundaySuite Supabase project
# (same project as SundayChess/Market/Turnering/Quiz) — SundayLicks lives in
# its own `licks` Postgres schema. After running supabase/migrations the
# `licks` schema MUST be added under Settings → API → Exposed schemas.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY
NEXT_PUBLIC_APP_URL=https://licks.sundaysuite.app

# Service-role key. Needed for:
#   - `npm run seed` (upserts curated licks), and
#   - the Fase 4 write paths: /api/submit (user submissions) + /api/admin/licks.
# In production set it as a Worker secret: `wrangler secret put SUPABASE_SERVICE_ROLE_KEY`.
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# Password for the /admin moderation page. In production:
#   `wrangler secret put ADMIN_PASSWORD`
ADMIN_PASSWORD=choose-a-strong-password
